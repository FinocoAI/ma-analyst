# === API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# FMP: company search may work on lower tiers; earnings call transcripts often need a paid plan (402 = upgrade).
FMP_API_KEY=your_fmp_api_key_here
EXA_API_KEY=your_exa_api_key_here

# === Claude Config ===
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_RETRIES=3
CLAUDE_TIMEOUT_SECONDS=60

# === Pipeline Defaults ===
DEFAULT_NUM_RESULTS=25
DEFAULT_GEOGRAPHY=India
TRANSCRIPT_QUARTERS=6
MAX_CONCURRENT_CLAUDE_CALLS=10
# Prospect funnel: multiplier * num_results (capped by PROSPECT_MAX_INTERNAL), trim after scoring
PROSPECT_OVERFETCH_MULTIPLIER=2.0
PROSPECT_MAX_INTERNAL=60
# strict = regex gate before Claude on transcripts; off = always run extraction
SIGNAL_PREFILTER_MODE=strict
# Optional Exa web/IR snippets in addition to earnings transcripts (extra API calls)
EXA_SIGNAL_ENRICHMENT=false
EXA_SIGNAL_ENRICHMENT_MAX_RESULTS=5
# Step 1: use Exa /contents when the homepage is a thin JS shell (Siemens-style)
EXA_PROFILE_FALLBACK=true
EXA_PROFILE_MAX_CHARACTERS=25000
# Optional: pip install -e ".[playwright]" && playwright install chromium
PLAYWRIGHT_ENABLED=false

# === Cache ===
CACHE_TTL_SECONDS=86400

# === Server ===
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./ma_prospecting.db
